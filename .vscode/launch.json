{
    "version": "2.0.0",
    "configurations": [
        //* ---- SFML Debug ----
        {
            "name": "Build SFML Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "cmd.exe",
            "args": ["/c", "echo Building SFML Debug..."],
            "preLaunchTask": "Build SFML Debug",
            "internalConsoleOptions": "neverOpen"
        },

        //* ---- SFML Release ----
        {
            "name": "Build SFML Release",
            "type": "cppdbg",
            "request": "launch",
            "program": "cmd.exe",
            "args": ["/c", "echo Building SFML Release..."],
            "preLaunchTask": "Build SFML Release",
            "internalConsoleOptions": "neverOpen"
        },


        //* ---- PROJECT RELEASE ----
        {
            "name": "Release GUI",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-release/gui/gui.exe",
            "cwd": "${workspaceFolder}/build-release/gui",
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "CMake Build Project Release"
        },

        //* ---- PROJECT DEBUG ----
        {
            "name": "Debug GUI",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-debug/gui/gui.exe",
            "cwd": "${workspaceFolder}/build-debug/gui",
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "CMake Build Project Debug"
        },
        {
            "name": "Debug Engine",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-debug/engine/engine_test.exe",
            "cwd": "${workspaceFolder}/build-debug/engine",
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "Configure & Build Engine Test"
        },
        {
            "name": "Debug Bot",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-debug/chess_bot/chess_bot_test.exe",
            "cwd": "${workspaceFolder}/build-debug/chess_bot",
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "Configure & Build Bot"
        }
    ]
}
