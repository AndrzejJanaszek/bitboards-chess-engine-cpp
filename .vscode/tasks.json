{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure SFML Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}/SFML-3.0.2",
                "-B", "${workspaceFolder}/SFML-3.0.2/build-debug",
                "-G", "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DBUILD_SHARED_LIBS=OFF"
            ]
        },
        {
            "label": "Build SFML Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/SFML-3.0.2/build-debug"
            ],
            "dependsOn": "Configure SFML Debug",
            "group": "build"
        },

        
        {
            "label": "Configure SFML Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}/SFML-3.0.2",
                "-B", "${workspaceFolder}/SFML-3.0.2/build-release",
                "-G", "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBUILD_SHARED_LIBS=OFF"
            ]
        },
        {
            "label": "Build SFML Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/SFML-3.0.2/build-release"
            ],
            "dependsOn": "Configure SFML Release",
            "group": "build"
        },


        {
            "label": "CMake Configure Project",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build",
                "-G", "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug"
            ]
        },
        {
            "label": "CMake Build Project",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--config", "Debug"
            ],
            "dependsOn": "CMake Configure Project",
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "Build Engine Test Only",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--target", "engine_test"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Build only the engine_test executable"
        },
        {
            "label": "Configure & Build Engine Test",
            "dependsOn": ["CMake Configure Project", "Build Engine Test Only"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Chess Bot Test Only",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--target", "chess_bot_test"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Build only the chess_bot_test executable"
        },
        {
            "label": "Configure & Build Bot",
            "dependsOn": ["CMake Configure Project", "Build Chess Bot Test Only"],
            "group": "build",
            "problemMatcher": []
        }
    ]
}
